# Backend Environment Configurations
DATABASE_URL=sqlite:///./hostel_biometric.db
SECRET_KEY=generate_a_secure_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Network Permissions (Comma separated CIDR rules)
# CAUTION: 127.0.0.1/32 is allowed for localized development testing.
# Remove it in production to restrict access to strict local network bands like 192.168.0.0/16
ALLOWED_SUBNET=127.0.0.1/32,172.16.0.0/12
